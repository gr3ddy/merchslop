generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  EMPLOYEE
  PROGRAM_ADMIN
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum PasswordActionTokenType {
  INVITE
  RESET_PASSWORD
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum TransactionType {
  ACCRUAL
  ADJUSTMENT
  RESERVE
  WRITE_OFF
  RELEASE
  EXPIRATION
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  CANCELED
}

enum ProductStatus {
  ACTIVE
  HIDDEN
  ARCHIVED
}

enum OrderStatus {
  CREATED
  CONFIRMED
  ASSEMBLED
  ISSUED
  CANCELED
}

enum NotificationType {
  BALANCE_ACCRUAL
  BALANCE_ADJUSTMENT
  ORDER_CREATED
  ORDER_CONFIRMED
  ORDER_ASSEMBLED
  ORDER_ISSUED
  ORDER_CANCELED
  POINTS_EXPIRING
  POINTS_EXPIRED
  SYSTEM
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

model CompanySettings {
  id                     String       @id @default("default")
  companyName            String
  currencyName           String       @default("Баллы")
  logoUrl                String?
  primaryColor           String?
  expirationMonths       Int          @default(12)
  expirationWarningDays  Int          @default(30)
  smtpEnabled            Boolean      @default(false)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  pickupPoints           PickupPoint[]
}

model PickupPoint {
  id                String          @id @default(uuid()) @db.Uuid
  name              String
  description       String?
  address           String?
  isActive          Boolean         @default(true)
  companySettingsId String          @default("default")
  companySettings   CompanySettings @relation(fields: [companySettingsId], references: [id], onDelete: Cascade)
  orders            Order[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([companySettingsId])
}

model User {
  id                  String        @id @default(uuid()) @db.Uuid
  email               String        @unique
  login               String?       @unique
  passwordHash        String?
  role                UserRole
  status              UserStatus    @default(ACTIVE)
  employeeId          String?       @unique @db.Uuid
  employee            Employee?     @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  lastLoginAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  authoredTransactions Transaction[] @relation("TransactionAuthor")
  notifications       Notification[]
  passwordActionTokens PasswordActionToken[]
  auditEvents         AuditEvent[]
  importJobs          ImportJob[]   @relation("ImportInitiator")
  canceledOrders      Order[]       @relation("OrderCanceledBy")
}

model PasswordActionToken {
  id         String                  @id @default(uuid()) @db.Uuid
  userId     String                  @db.Uuid
  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       PasswordActionTokenType
  tokenHash  String                  @unique
  expiresAt  DateTime
  consumedAt DateTime?
  issuedById String?                 @db.Uuid
  createdAt  DateTime                @default(now())

  @@index([userId, type, expiresAt])
  @@index([type, expiresAt])
}

model Employee {
  id              String          @id @default(uuid()) @db.Uuid
  employeeNumber  String          @unique
  fullName        String
  email           String          @unique
  department      String?
  position        String?
  managerName     String?
  hireDate        DateTime?
  status          EmployeeStatus  @default(ACTIVE)
  branch          String?
  legalEntity     String?
  user            User?
  balanceSnapshot BalanceSnapshot?
  transactions    Transaction[]
  orders          Order[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([department])
  @@index([status])
}

model BalanceSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  employeeId     String   @unique @db.Uuid
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  availableAmount Decimal  @default(0) @db.Decimal(12, 2)
  reservedAmount Decimal   @default(0) @db.Decimal(12, 2)
  updatedAt      DateTime @updatedAt
}

model AccrualReason {
  id                 String        @id @default(uuid()) @db.Uuid
  code               String        @unique
  title              String
  description        String?
  appliesToAccrual   Boolean       @default(true)
  appliesToAdjustment Boolean      @default(false)
  isActive           Boolean       @default(true)
  transactions       Transaction[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Transaction {
  id                       String             @id @default(uuid()) @db.Uuid
  employeeId               String             @db.Uuid
  employee                 Employee           @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  authorId                 String?            @db.Uuid
  author                   User?              @relation("TransactionAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  type                     TransactionType
  status                   TransactionStatus  @default(CONFIRMED)
  amount                   Decimal            @db.Decimal(12, 2)
  reasonId                 String?            @db.Uuid
  reason                   AccrualReason?     @relation(fields: [reasonId], references: [id], onDelete: SetNull)
  orderId                  String?            @db.Uuid
  order                    Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  sourceTransactionId      String?            @db.Uuid
  sourceTransaction        Transaction?       @relation("TransactionCompensation", fields: [sourceTransactionId], references: [id], onDelete: SetNull)
  compensationTransactions Transaction[]      @relation("TransactionCompensation")
  comment                  String?
  metadata                 Json?
  effectiveAt              DateTime           @default(now())
  expiresAt                DateTime?
  createdAt                DateTime           @default(now())

  @@index([employeeId, createdAt])
  @@index([orderId])
  @@index([type, status])
  @@index([expiresAt])
}

model ProductCategory {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id               String        @id @default(uuid()) @db.Uuid
  sku              String        @unique
  title            String
  description      String?
  pricePoints      Decimal       @db.Decimal(12, 2)
  stockQty         Int           @default(0)
  hasUnlimitedStock Boolean      @default(false)
  status           ProductStatus @default(ACTIVE)
  categoryId       String?       @db.Uuid
  category         ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images           ProductImage[]
  orderItems       OrderItem[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
  @@index([categoryId])
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  filePath  String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Order {
  id            String      @id @default(uuid()) @db.Uuid
  employeeId    String      @db.Uuid
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  status        OrderStatus @default(CREATED)
  pickupPointId String?     @db.Uuid
  pickupPoint   PickupPoint? @relation(fields: [pickupPointId], references: [id], onDelete: SetNull)
  reservedAmount Decimal    @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal     @default(0) @db.Decimal(12, 2)
  comment       String?
  confirmedAt   DateTime?
  assembledAt   DateTime?
  issuedAt      DateTime?
  canceledAt    DateTime?
  canceledById  String?     @db.Uuid
  canceledBy    User?       @relation("OrderCanceledBy", fields: [canceledById], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
  transactions  Transaction[]

  @@index([employeeId, createdAt])
  @@index([status])
  @@index([pickupPointId])
}

model OrderItem {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @db.Uuid
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String   @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity   Int
  pricePoints Decimal @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([orderId, productId])
  @@index([productId])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([type])
}

model AuditEvent {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model ImportJob {
  id            String          @id @default(uuid()) @db.Uuid
  fileName      String
  status        ImportJobStatus @default(PENDING)
  rowsTotal     Int             @default(0)
  rowsSucceeded Int             @default(0)
  rowsFailed    Int             @default(0)
  summary       Json?
  initiatedById String?         @db.Uuid
  initiatedBy   User?           @relation("ImportInitiator", fields: [initiatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}
