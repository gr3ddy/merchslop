{
  "name": "merchshop-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend foundation for Merchshop MVP",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "nest build",
    "postinstall": "prisma generate",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "test:critical": "npm run build && node --env-file=.env --test test/critical-flows.test.mjs",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.prisma\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.0.0",
    "nodemailer": "^8.0.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^7.0.11",
    "prettier": "^3.4.0",
    "prisma": "^6.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.0"
  }
}
